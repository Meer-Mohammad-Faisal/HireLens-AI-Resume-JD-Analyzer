PORT=3000
NODE_ENV=development
TRUST_PROXY=false

MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>
MONGO_DIRECT_URI=

JWT_SECRET=replace-with-a-strong-random-secret
